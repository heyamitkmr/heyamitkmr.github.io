    <feeder:settings>
      <feeder:setting key="pref_show_fab" value="false"/>
      <feeder:setting key="prefs_filter_recently_read" value="false"/>
      <feeder:setting key="pref_show_reading_time" value="true"/>
      <feeder:setting key="pref_is_mark_as_read_on_scroll" value="false"/>
      <feeder:setting key="pref_sync_freq" value="1440"/>
      <feeder:setting key="pref_added_feeder_news" value="true"/>
      <feeder:setting key="pref_open_drawer_on_fab" value="true"/>
      <feeder:setting key="pref_theme" value="system"/>
      <feeder:setting key="pref_max_item_count_per_feed" value="50"/>
      <feeder:setting key="pref_show_title_unread_count" value="true"/>
      <feeder:setting key="pref_swipe_as_read" value="DISABLED"/>
      <feeder:setting key="pref_sync_on_resume" value="true"/>
      <feeder:setting key="prefs_filter_read" value="false"/>
    </feeder:settings>
